# ===========================================
# ManufactureHub Environment Variables
# ===========================================

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/manufacturehub
REDIS_URL=redis://localhost:6379

# Authentication (Clerk)
CLERK_PUBLISHABLE_KEY=pk_test_xxxxx
CLERK_SECRET_KEY=sk_test_xxxxx
CLERK_WEBHOOK_SECRET=whsec_xxxxx

# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Alibaba Cloud API
ALIBABA_ACCESS_KEY_ID=xxxxx
ALIBABA_ACCESS_KEY_SECRET=xxxxx
ALIBABA_REGION=us-east-1

# File Storage (AWS S3 / Cloudflare R2)
S3_BUCKET_NAME=manufacturehub-assets
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=xxxxx
S3_SECRET_ACCESS_KEY=xxxxx
S3_ENDPOINT=  # Leave empty for AWS S3, set for R2

# Email (SendGrid / Resend)
SENDGRID_API_KEY=SG.xxxxx
EMAIL_FROM=noreply@manufacturehub.com

# Stripe Billing
STRIPE_SECRET_KEY=sk_test_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx
STRIPE_PRICE_ID_PRO=price_xxxxx
STRIPE_PRICE_ID_ENTERPRISE=price_xxxxx

# Shipping (EasyPost)
EASYPOST_API_KEY=xxxxx

# Slack Integration (Optional)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxxxx

# Sentry (Optional)
SENTRY_DSN=https://xxxxx@sentry.io/xxxxx

# App Config
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:5173
API_URL=http://localhost:3001
JWT_SECRET=change-me-in-production
CORS_ORIGINS=http://localhost:5173
