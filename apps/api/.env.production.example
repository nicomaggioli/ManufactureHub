# ===========================================
# ManufactureHub API - Production Environment
# ===========================================
# Copy this to .env and fill in values before deploying.
# Railway auto-injects DATABASE_URL when you provision PostgreSQL.

# ---- REQUIRED ----

# Database (auto-set by Railway when PostgreSQL is provisioned)
DATABASE_URL=postgresql://user:pass@host:5432/railway

# Auth secret for signing JWTs (min 32 characters)
JWT_SECRET=

# Server
NODE_ENV=production
PORT=3001

# Allowed frontend origins (comma-separated)
CORS_ORIGINS=https://your-frontend-domain.com

# ---- OPTIONAL ----

# REDIS_URL=redis://localhost:6379
# CLERK_PUBLISHABLE_KEY=
# CLERK_SECRET_KEY=
# CLERK_WEBHOOK_SECRET=
# ANTHROPIC_API_KEY=
# ALIBABA_ACCESS_KEY_ID=
# ALIBABA_ACCESS_KEY_SECRET=
# S3_BUCKET_NAME=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# SENDGRID_API_KEY=
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# EASYPOST_API_KEY=
# SLACK_WEBHOOK_URL=
# SENTRY_DSN=
