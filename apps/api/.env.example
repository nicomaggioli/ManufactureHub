# App
NODE_ENV=development
PORT=3001
CORS_ORIGINS=http://localhost:5173
JWT_SECRET=dev-secret-change-in-production

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/manufacturehub

# Redis (optional — server works without it; background workers need it)
REDIS_URL=redis://localhost:6379

# Anthropic (AI features)
ANTHROPIC_API_KEY=sk-ant-...

# Alibaba (manufacturer import)
ALIBABA_APP_KEY=
ALIBABA_APP_SECRET=

# SendGrid (email notifications)
SENDGRID_API_KEY=SG....
SENDGRID_FROM_EMAIL=noreply@manufacturehub.io

# S3 (file uploads / design assets)
S3_BUCKET=manufacturehub
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# S3_ENDPOINT=  # Optional — set for S3-compatible services (MinIO, R2, etc.)

# Stripe (billing)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
